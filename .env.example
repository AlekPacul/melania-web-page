# Supabase — public (safe to expose in browser)
# Get from: Supabase Dashboard > Project Settings > API
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your_publishable_key_here

# Supabase — secret (server-only, NEVER prefix with NUXT_PUBLIC_)
# Get from: Supabase Dashboard > Project Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
